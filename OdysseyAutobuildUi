local function makeLabel(parent, size, pos, font, textSize, color, text, xAlign, zIndex)
    local l = Instance.new("TextLabel")
    l.Size = size
    l.Position = pos
    l.BackgroundTransparency = 1
    l.Font = font
    l.TextSize = textSize
    l.TextColor3 = color
    l.Text = text
    l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
    l.ZIndex = zIndex or 2
    l.Parent = parent
    return l
end

local function makeStatCell(parent, labelText)
    local cell = Instance.new("Frame")
    cell.Size = UDim2.new(0.333, -2, 0, 28)
    cell.BackgroundColor3 = Color3.fromRGB(26, 26, 30)
    cell.BorderSizePixel = 0
    cell.ZIndex = 3
    cell.Parent = parent
    Instance.new("UICorner", cell).CornerRadius = UDim.new(0, 4)

    makeLabel(cell, UDim2.new(1,0,0,10), UDim2.new(0,0,0,2), Enum.Font.GothamBold, 7, Color3.fromRGB(90,90,104), labelText, Enum.TextXAlignment.Center, 3)
    local val = makeLabel(cell, UDim2.new(1,0,0,14), UDim2.new(0,0,0,12), Enum.Font.GothamBold, 10, Color3.fromRGB(176,176,190), "0", Enum.TextXAlignment.Center, 3)
    return cell, val
end


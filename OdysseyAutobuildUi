local AutoBuild = {}
AutoBuild.Frame = win

function AutoBuild:SetWood(name, have, need, missing)
    local ref = woodRefs[name]
    if not ref then return end
    ref.haveVal.Text = tostring(have)
    ref.needVal.Text = tostring(need)
    ref.missVal.Text = tostring(missing)
    if missing > 0 then
        ref.missCell.BackgroundColor3 = Color3.fromRGB(46, 26, 26)
        ref.missVal.TextColor3 = Color3.fromRGB(248, 113, 113)
    else
        ref.missCell.BackgroundColor3 = Color3.fromRGB(26, 26, 30)
        ref.missVal.TextColor3 = Color3.fromRGB(34, 197, 94)
    end
end

function AutoBuild:Show()
    win.Visible = true
    win.Size = UDim2.new(0, 380, 0, 0)
    TweenService:Create(win, TweenInfo.new(0.35, Enum.EasingStyle.Exponential), {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 380, 0, 440)
    }):Play()
end

function AutoBuild:Hide()
    TweenService:Create(win, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 380, 0, 0)
    }):Play()
    task.wait(0.31)
    win.Visible = false
end

function AutoBuild:Destroy()
    AutoBuildGUI:Destroy()
end

return AutoBuild

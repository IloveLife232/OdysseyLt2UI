local function ShowChangelog()
    if game.Players.LocalPlayer.PlayerGui:FindFirstChild("OdysseyChangelog") then
        game.Players.LocalPlayer.PlayerGui.OdysseyChangelog:Destroy()
        return
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "OdysseyChangelog"
    gui.ResetOnSpawn = false
    gui.Parent = game.Players.LocalPlayer.PlayerGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 400, 0, 500)
    bg.Position = UDim2.new(0.5, -200, 0.5, -250)
    bg.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
    bg.BorderSizePixel = 0
    bg.Parent = gui
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 8)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -60, 0, 30)
    title.Position = UDim2.new(0, 10, 0, 10)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Font = Enum.Font.GothamBold
    title.TextSize = 16
    title.Text = "Odyssey Changelog"
    title.Parent = bg

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -40, 0, 10)
    closeBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 52)
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 14
    closeBtn.Text = "X"
    closeBtn.Parent = bg
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)
    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(1, -20, 0, 1)
    divider.Position = UDim2.new(0, 10, 0, 48)
    divider.BackgroundColor3 = Color3.fromRGB(60, 60, 62)
    divider.BorderSizePixel = 0
    divider.Parent = bg

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -20, 1, -65)
    scroll.Position = UDim2.new(0, 10, 0, 58)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 255)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.Parent = bg

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = scroll

    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingRight = UDim.new(0, 5)
    padding.Parent = scroll

    local changelog = {
        {
            version = "Version 3.0 (Testers)",
            date = "May 31 2026",
            changes = {
                "Rebuilt entire script for V3",
                "Renamed tabs - Player, World, Property, Wood, Building, Auto Buy, Dupe, Auto Build, Settings",
                "Added progress bar system with ETA",
                "Progress bar added to Auto Buy, Blueprint Buy, Rukiryaxe Buy and Get Tree",
                "Rebuilt Auto Buy with better reliability",
                "Added open boxes toggle for blueprint auto buy",
                "Added abort support for Auto Buy, Rukiryaxe and Blueprints",
                "Rukiryaxe now uses amount slider",
                "Added Rainbow Vehicle with original color restore",
                "Changed LT2 UI to Odyssey dark theme",
                "Added Odyssey Changelog viewer",
                "Added Support Odyssey donation links",
                "Added Welcome notification on load",
                "Improved Get Tree for all wood types including CaveCrawler, Koa, Pine and Fir",
                "Fixed blueprint boxes teleporting back after purchase",
                "Added Fill All Blueprints button",
                "Added Sell Logs with abort and earnings tracker",
                "Added Mod Sawmill with blueprint check",
                "Added View End Tree with LoneCave detection",
                "Improved fly with better stability",
                "Moved teleports from Player tab to World tab",
                "Added Mary Statue waypoint",
                "Added Select Player Base teleport dropdown",
                "Added Anti AFK label in settings",
            }
        },
        {
            version = "Version 2.0",
            date = "2024",
            changes = {
                "Initial release of Odyssey",
                "Added Auto Buy",
                "Added Get Tree",
                "Added Dupe",
                "Added Fly",
                "Added No Clip",
                "Added Teleports",
            }
        }
    }

    for _, entry in ipairs(changelog) do
        local versionLabel = Instance.new("TextLabel")
        versionLabel.Size = UDim2.new(1, 0, 0, 22)
        versionLabel.BackgroundTransparency = 1
        versionLabel.TextColor3 = Color3.fromRGB(0, 150, 255)
        versionLabel.TextXAlignment = Enum.TextXAlignment.Left
        versionLabel.Font = Enum.Font.GothamBold
        versionLabel.TextSize = 13
        versionLabel.Text = entry.version .. " - " .. entry.date
        versionLabel.Parent = scroll

        for _, change in ipairs(entry.changes) do
            local changeLabel = Instance.new("TextLabel")
            changeLabel.Size = UDim2.new(1, 0, 0, 0)
            changeLabel.AutomaticSize = Enum.AutomaticSize.Y
            changeLabel.BackgroundTransparency = 1
            changeLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            changeLabel.TextXAlignment = Enum.TextXAlignment.Left
            changeLabel.TextWrapped = true
            changeLabel.Font = Enum.Font.Gotham
            changeLabel.TextSize = 11
            changeLabel.Text = "- " .. change
            changeLabel.Parent = scroll
        end

        local spacer = Instance.new("Frame")
        spacer.Size = UDim2.new(1, 0, 0, 8)
        spacer.BackgroundTransparency = 1
        spacer.Parent = scroll
    end

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
end

ShowChangelog()

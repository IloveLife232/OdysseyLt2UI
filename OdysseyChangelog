local function ShowChangelog()
    if game.Players.LocalPlayer.PlayerGui:FindFirstChild("OdysseyChangelog") then
        game.Players.LocalPlayer.PlayerGui.OdysseyChangelog:Destroy()
        return
    end

    local TweenService = game:GetService("TweenService")
    local tweenFast = TweenInfo.new(0.2, Enum.EasingStyle.Exponential)
    local tweenMed = TweenInfo.new(0.35, Enum.EasingStyle.Exponential)

    local gui = Instance.new("ScreenGui")
    gui.Name = "OdysseyChangelog"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    if syn and syn.protect_gui then
        syn.protect_gui(gui)
        gui.Parent = game:GetService("CoreGui")
    elseif gethui then
        gui.Parent = gethui()
    else
        gui.Parent = game.Players.LocalPlayer.PlayerGui
    end

    -- backdrop
    local backdrop = Instance.new("Frame")
    backdrop.Size = UDim2.new(1, 0, 1, 0)
    backdrop.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    backdrop.BackgroundTransparency = 0.45
    backdrop.BorderSizePixel = 0
    backdrop.ZIndex = 1
    backdrop.Parent = gui

    -- main window
    local win = Instance.new("Frame")
    win.Size = UDim2.new(0, 400, 0, 480)
    win.Position = UDim2.new(0.5, -200, 0.5, -240)
    win.BackgroundColor3 = Color3.fromRGB(26, 26, 30)
    win.BackgroundTransparency = 1
    win.BorderSizePixel = 0
    win.ZIndex = 2
    win.Parent = gui
    Instance.new("UICorner", win).CornerRadius = UDim.new(0, 10)

    local winStroke = Instance.new("UIStroke")
    winStroke.Color = Color3.fromRGB(58, 58, 68)
    winStroke.Thickness = 1
    winStroke.Parent = win

    -- animate in
    win.Size = UDim2.new(0, 400, 0, 0)
    TweenService:Create(win, tweenMed, {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 400, 0, 480)
    }):Play()

    -- topbar
    local topbar = Instance.new("Frame")
    topbar.Size = UDim2.new(1, 0, 0, 46)
    topbar.BackgroundColor3 = Color3.fromRGB(26, 26, 30)
    topbar.BorderSizePixel = 0
    topbar.ZIndex = 3
    topbar.Parent = win
    Instance.new("UICorner", topbar).CornerRadius = UDim.new(0, 10)

    local topbarLine = Instance.new("Frame")
    topbarLine.Size = UDim2.new(1, 0, 0, 1)
    topbarLine.Position = UDim2.new(0, 0, 1, -1)
    topbarLine.BackgroundColor3 = Color3.fromRGB(58, 58, 68)
    topbarLine.BorderSizePixel = 0
    topbarLine.ZIndex = 3
    topbarLine.Parent = topbar

    -- icon box
    local iconBox = Instance.new("Frame")
    iconBox.Size = UDim2.new(0, 28, 0, 28)
    iconBox.Position = UDim2.new(0, 10, 0.5, -14)
    iconBox.BackgroundColor3 = Color3.fromRGB(44, 44, 52)
    iconBox.BorderSizePixel = 0
    iconBox.ZIndex = 3
    iconBox.Parent = topbar
    Instance.new("UICorner", iconBox).CornerRadius = UDim.new(0, 6)

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 1, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.TextColor3 = Color3.fromRGB(61, 155, 255)
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextSize = 14
    iconLabel.Text = "CL"
    iconLabel.ZIndex = 3
    iconLabel.Parent = iconBox

    -- title
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -90, 0, 18)
    titleLabel.Position = UDim2.new(0, 46, 0, 7)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = Color3.fromRGB(232, 232, 238)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 13
    titleLabel.Text = "Odyssey Changelog"
    titleLabel.ZIndex = 3
    titleLabel.Parent = topbar

    local subLabel = Instance.new("TextLabel")
    subLabel.Size = UDim2.new(1, -90, 0, 14)
    subLabel.Position = UDim2.new(0, 46, 0, 26)
    subLabel.BackgroundTransparency = 1
    subLabel.TextColor3 = Color3.fromRGB(90, 90, 104)
    subLabel.TextXAlignment = Enum.TextXAlignment.Left
    subLabel.Font = Enum.Font.Gotham
    subLabel.TextSize = 10
    subLabel.Text = "version history"
    subLabel.ZIndex = 3
    subLabel.Parent = topbar

    -- close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 26, 0, 26)
    closeBtn.Position = UDim2.new(1, -36, 0.5, -13)
    closeBtn.BackgroundColor3 = Color3.fromRGB(44, 44, 52)
    closeBtn.TextColor3 = Color3.fromRGB(122, 122, 138)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 13
    closeBtn.Text = "✕"
    closeBtn.BorderSizePixel = 0
    closeBtn.ZIndex = 3
    closeBtn.Parent = topbar
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

    local closeBtnStroke = Instance.new("UIStroke")
    closeBtnStroke.Color = Color3.fromRGB(58, 58, 68)
    closeBtnStroke.Thickness = 1
    closeBtnStroke.Parent = closeBtn

    closeBtn.MouseEnter:Connect(function()
        TweenService:Create(closeBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(58, 58, 68), TextColor3 = Color3.fromRGB(232, 232, 238)}):Play()
    end)
    closeBtn.MouseLeave:Connect(function()
        TweenService:Create(closeBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(44, 44, 52), TextColor3 = Color3.fromRGB(122, 122, 138)}):Play()
    end)

    local function closeGUI()
        TweenService:Create(win, tweenMed, {BackgroundTransparency = 1, Size = UDim2.new(0, 400, 0, 0)}):Play()
        TweenService:Create(backdrop, tweenFast, {BackgroundTransparency = 1}):Play()
        task.wait(0.36)
        gui:Destroy()
    end

    closeBtn.MouseButton1Click:Connect(closeGUI)
    backdrop.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            closeGUI()
        end
    end)

    -- content area
    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, 0, 1, -47)
    content.Position = UDim2.new(0, 0, 0, 47)
    content.BackgroundColor3 = Color3.fromRGB(34, 34, 40)
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = Color3.fromRGB(61, 155, 255)
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.ZIndex = 2
    content.Parent = win
    Instance.new("UICorner", content).CornerRadius = UDim.new(0, 10)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 4)
    layout.Parent = content

    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0, 10)
    pad.PaddingBottom = UDim.new(0, 12)
    pad.PaddingLeft = UDim.new(0, 10)
    pad.PaddingRight = UDim.new(0, 10)
    pad.Parent = content

    local changes = {
        "Rebuilt entire script for V3",
        "Renamed tabs — Player, World, Property, Wood, Building, Auto Buy, Dupe, Auto Build, Settings",
        "Added progress bar system with ETA",
        "Progress bar added to Auto Buy, Blueprint Buy, Rukiryaxe Buy and Get Tree",
        "Rebuilt Auto Buy with better reliability",
        "Added open boxes toggle for blueprint auto buy",
        "Added abort support for Auto Buy, Rukiryaxe and Blueprints",
        "Rukiryaxe now uses amount slider",
        "Added Rainbow Vehicle with original color restore",
        "Changed LT2 UI to Odyssey dark theme",
        "Added Odyssey Changelog viewer",
        "Added Support Odyssey donation links",
        "Added Welcome notification on load",
        "Improved Get Tree for all wood types including CaveCrawler, Koa, Pine and Fir",
        "Fixed blueprint boxes teleporting back after purchase",
        "Added Fill All Blueprints button",
        "Added Sell Logs with abort and earnings tracker",
        "Added Mod Sawmill with blueprint check",
        "Added View End Tree with LoneCave detection",
        "Improved fly with better stability",
        "Moved teleports from Player tab to World tab",
        "Added Mary Statue waypoint",
        "Added Select Player Base teleport dropdown",
        "Added Anti AFK label in settings",
    }

    local order = 0

    -- version header row
    local verRow = Instance.new("Frame")
    verRow.LayoutOrder = order order += 1
    verRow.Size = UDim2.new(1, 0, 0, 18)
    verRow.BackgroundTransparency = 1
    verRow.BorderSizePixel = 0
    verRow.ZIndex = 2
    verRow.Parent = content

    local verName = Instance.new("TextLabel")
    verName.Size = UDim2.new(0, 100, 1, 0)
    verName.BackgroundTransparency = 1
    verName.TextColor3 = Color3.fromRGB(61, 155, 255)
    verName.TextXAlignment = Enum.TextXAlignment.Left
    verName.Font = Enum.Font.GothamBold
    verName.TextSize = 11
    verName.Text = "v3.0 Testers"
    verName.ZIndex = 2
    verName.Parent = verRow

    local verLine = Instance.new("Frame")
    verLine.Size = UDim2.new(1, -160, 0, 1)
    verLine.Position = UDim2.new(0, 105, 0.5, 0)
    verLine.BackgroundColor3 = Color3.fromRGB(58, 58, 68)
    verLine.BorderSizePixel = 0
    verLine.ZIndex = 2
    verLine.Parent = verRow

    local verDate = Instance.new("TextLabel")
    verDate.Size = UDim2.new(0, 80, 1, 0)
    verDate.Position = UDim2.new(1, -80, 0, 0)
    verDate.BackgroundTransparency = 1
    verDate.TextColor3 = Color3.fromRGB(90, 90, 104)
    verDate.TextXAlignment = Enum.TextXAlignment.Right
    verDate.Font = Enum.Font.Gotham
    verDate.TextSize = 10
    verDate.Text = "May 31 2026"
    verDate.ZIndex = 2
    verDate.Parent = verRow

    -- change entries
    for _, change in ipairs(changes) do
        local row = Instance.new("Frame")
        row.LayoutOrder = order order += 1
        row.Size = UDim2.new(1, 0, 0, 0)
        row.AutomaticSize = Enum.AutomaticSize.Y
        row.BackgroundColor3 = Color3.fromRGB(44, 44, 52)
        row.BorderSizePixel = 0
        row.ZIndex = 2
        row.Parent = content
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

        local rowStroke = Instance.new("UIStroke")
        rowStroke.Color = Color3.fromRGB(58, 58, 68)
        rowStroke.Thickness = 1
        rowStroke.Parent = row

        local rowPad = Instance.new("UIPadding")
        rowPad.PaddingTop = UDim.new(0, 6)
        rowPad.PaddingBottom = UDim.new(0, 6)
        rowPad.PaddingLeft = UDim.new(0, 10)
        rowPad.PaddingRight = UDim.new(0, 10)
        rowPad.Parent = row

        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 5, 0, 5)
        dot.Position = UDim2.new(0, 0, 0, 5)
        dot.BackgroundColor3 = Color3.fromRGB(61, 155, 255)
        dot.BorderSizePixel = 0
        dot.ZIndex = 2
        dot.Parent = row
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, -14, 0, 0)
        txt.Position = UDim2.new(0, 14, 0, 0)
        txt.AutomaticSize = Enum.AutomaticSize.Y
        txt.BackgroundTransparency = 1
        txt.TextColor3 = Color3.fromRGB(176, 176, 190)
        txt.TextXAlignment = Enum.TextXAlignment.Left
        txt.TextWrapped = true
        txt.Font = Enum.Font.Gotham
        txt.TextSize = 11
        txt.Text = change
        txt.ZIndex = 2
        txt.Parent = row
    end

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        content.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 24)
    end)
    content.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 24)
end

ShowChangelog()

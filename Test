local MobileUI = {}
MobileUI.__index = MobileUI

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local player = game.Players.LocalPlayer

local COLORS = {
    bg = Color3.fromRGB(22, 22, 24),
    sidebar = Color3.fromRGB(28, 28, 30),
    card = Color3.fromRGB(38, 38, 40),
    innerCard = Color3.fromRGB(48, 48, 52),
    text = Color3.fromRGB(255, 255, 255),
    textSecondary = Color3.fromRGB(160, 160, 165),
    accent = Color3.fromRGB(0, 150, 255),
    toggle_on = Color3.fromRGB(0, 150, 255),
    toggle_off = Color3.fromRGB(80, 80, 85),
    divider = Color3.fromRGB(60, 60, 62),
}

local function corner(parent, radius)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, radius or 6)
    return c
end

local function padding(parent, top, left, right, bottom)
    local p = Instance.new("UIPadding", parent)
    p.PaddingTop = UDim.new(0, top or 8)
    p.PaddingLeft = UDim.new(0, left or 8)
    p.PaddingRight = UDim.new(0, right or 8)
    p.PaddingBottom = UDim.new(0, bottom or 8)
    return p
end

function MobileUI.new(title)
    local self = setmetatable({}, MobileUI)
    self.tabs = {}
    self.currentTab = nil
    self.visible = true

    -- main gui
    local gui = Instance.new("ScreenGui")
    gui.Name = "OdysseyMobileUI"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = player.PlayerGui
    self.gui = gui

    -- main frame
    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, 380, 0, 500)
    main.Position = UDim2.new(0.5, -190, 0.5, -250)
    main.BackgroundColor3 = COLORS.bg
    main.BorderSizePixel = 0
    main.Parent = gui
    corner(main, 10)
    self.main = main

    -- topbar
    local topbar = Instance.new("Frame")
    topbar.Size = UDim2.new(1, 0, 0, 40)
    topbar.BackgroundColor3 = COLORS.sidebar
    topbar.BorderSizePixel = 0
    topbar.Parent = main
    corner(topbar, 10)

    -- fix topbar bottom corners
    local topbarFix = Instance.new("Frame")
    topbarFix.Size = UDim2.new(1, 0, 0, 10)
    topbarFix.Position = UDim2.new(0, 0, 1, -10)
    topbarFix.BackgroundColor3 = COLORS.sidebar
    topbarFix.BorderSizePixel = 0
    topbarFix.Parent = topbar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -80, 1, 0)
    titleLabel.Position = UDim2.new(0, 15, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = COLORS.text
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 14
    titleLabel.Text = title or "Odyssey"
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topbar

    -- close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -38, 0, 5)
    closeBtn.BackgroundColor3 = COLORS.card
    closeBtn.TextColor3 = COLORS.text
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 14
    closeBtn.Text = "X"
    closeBtn.Parent = topbar
    corner(closeBtn, 6)
    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

    -- minimize button
    local minBtn = Instance.new("TextButton")
    minBtn.Size = UDim2.new(0, 30, 0, 30)
    minBtn.Position = UDim2.new(1, -72, 0, 5)
    minBtn.BackgroundColor3 = COLORS.card
    minBtn.TextColor3 = COLORS.text
    minBtn.Font = Enum.Font.GothamBold
    minBtn.TextSize = 14
    minBtn.Text = "-"
    minBtn.Parent = topbar
    corner(minBtn, 6)

    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(main, TweenInfo.new(0.2), {Size = UDim2.new(0, 380, 0, 40)}):Play()
        else
            TweenService:Create(main, TweenInfo.new(0.2), {Size = UDim2.new(0, 380, 0, 500)}):Play()
        end
    end)

    -- body
    local body = Instance.new("Frame")
    body.Size = UDim2.new(1, 0, 1, -40)
    body.Position = UDim2.new(0, 0, 0, 40)
    body.BackgroundTransparency = 1
    body.Parent = main
    self.body = body

    -- sidebar
    local sidebar = Instance.new("ScrollingFrame")
    sidebar.Size = UDim2.new(0, 90, 1, 0)
    sidebar.BackgroundColor3 = COLORS.sidebar
    sidebar.BorderSizePixel = 0
    sidebar.ScrollBarThickness = 0
    sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    sidebar.AutomaticCanvasSize = Enum.AutomaticSize.Y
    sidebar.Parent = body
    self.sidebar = sidebar

    local sidebarLayout = Instance.new("UIListLayout", sidebar)
    sidebarLayout.Padding = UDim.new(0, 4)
    sidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    padding(sidebar, 8, 6, 6, 8)

    -- content area
    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, -90, 1, 0)
    content.Position = UDim2.new(0, 90, 0, 0)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 3
    content.ScrollBarImageColor3 = COLORS.accent
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.Parent = body
    self.content = content

    -- make draggable
    local dragging, dragStart, startPos = false, nil, nil
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return self
end

function MobileUI:CreateTab(name, icon)
    local tab = {}
    tab.name = name
    tab.elements = {}

    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, 0, 0, 70)
    tabBtn.BackgroundColor3 = COLORS.card
    tabBtn.BorderSizePixel = 0
    tabBtn.Text = ""
    tabBtn.Parent = self.sidebar
    corner(tabBtn, 8)

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 30)
    iconLabel.Position = UDim2.new(0, 0, 0, 8)
    iconLabel.BackgroundTransparency = 1
    iconLabel.TextColor3 = COLORS.textSecondary
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextSize = 18
    iconLabel.Text = icon or "●"
    iconLabel.Parent = tabBtn

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 20)
    nameLabel.Position = UDim2.new(0, 0, 0, 40)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = COLORS.textSecondary
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 10
    nameLabel.Text = name
    nameLabel.Parent = tabBtn

    -- content frame for this tab
    local tabContent = Instance.new("Frame")
    tabContent.Size = UDim2.new(1, 0, 1, 0)
    tabContent.BackgroundTransparency = 1
    tabContent.Visible = false
    tabContent.Parent = self.content

    local tabLayout = Instance.new("UIListLayout", tabContent)
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    padding(tabContent, 8, 8, 8, 8)

    tab.frame = tabContent
    tab.btn = tabBtn
    tab.iconLabel = iconLabel
    tab.nameLabel = nameLabel

    tabBtn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)

    table.insert(self.tabs, tab)

    if #self.tabs == 1 then
        self:SelectTab(tab)
    end

    return tab
end

function MobileUI:SelectTab(tab)
    for _, t in ipairs(self.tabs) do
        t.frame.Visible = false
        t.btn.BackgroundColor3 = COLORS.card
        t.iconLabel.TextColor3 = COLORS.textSecondary
        t.nameLabel.TextColor3 = COLORS.textSecondary
    end
    tab.frame.Visible = true
    tab.btn.BackgroundColor3 = COLORS.innerCard
    tab.iconLabel.TextColor3 = COLORS.accent
    tab.nameLabel.TextColor3 = COLORS.text
    self.currentTab = tab
end


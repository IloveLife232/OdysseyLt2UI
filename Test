function MobileUI:CreateDropdown(parent, options)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.AutomaticSize = Enum.AutomaticSize.Y
    frame.BackgroundColor3 = COLORS.card
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    frame.Parent = parent
    corner(frame, 8)

    local headerBtn = Instance.new("TextButton")
    headerBtn.Size = UDim2.new(1, 0, 0, 50)
    headerBtn.BackgroundTransparency = 1
    headerBtn.Text = ""
    headerBtn.Parent = frame

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -50, 0, 20)
    nameLabel.Position = UDim2.new(0, 10, 0, 8)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = COLORS.text
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.Text = options.Name or "Dropdown"
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = headerBtn

    local selectedLabel = Instance.new("TextLabel")
    selectedLabel.Size = UDim2.new(1, -20, 0, 16)
    selectedLabel.Position = UDim2.new(0, 10, 0, 28)
    selectedLabel.BackgroundTransparency = 1
    selectedLabel.TextColor3 = COLORS.accent
    selectedLabel.Font = Enum.Font.Gotham
    selectedLabel.TextSize = 11
    selectedLabel.Text = options.CurrentOption or "Select..."
    selectedLabel.TextXAlignment = Enum.TextXAlignment.Left
    selectedLabel.Parent = headerBtn

    local arrow = Instance.new("TextLabel")
    arrow.Size = UDim2.new(0, 20, 0, 20)
    arrow.Position = UDim2.new(1, -30, 0, 15)
    arrow.BackgroundTransparency = 1
    arrow.TextColor3 = COLORS.textSecondary
    arrow.Font = Enum.Font.GothamBold
    arrow.TextSize = 12
    arrow.Text = "v"
    arrow.Parent = headerBtn

    local optionsFrame = Instance.new("Frame")
    optionsFrame.Size = UDim2.new(1, 0, 0, 0)
    optionsFrame.Position = UDim2.new(0, 0, 0, 50)
    optionsFrame.BackgroundColor3 = COLORS.innerCard
    optionsFrame.BorderSizePixel = 0
    optionsFrame.Visible = false
    optionsFrame.Parent = frame

    local optLayout = Instance.new("UIListLayout", optionsFrame)
    optLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local function buildOptions(opts)
        for _, child in ipairs(optionsFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(opts) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 36)
            optBtn.BackgroundTransparency = 1
            optBtn.TextColor3 = COLORS.text
            optBtn.Font = Enum.Font.Gotham
            optBtn.TextSize = 11
            optBtn.Text = opt
            optBtn.TextXAlignment = Enum.TextXAlignment.Left
            padding(optBtn, 0, 12, 0, 0)
            optBtn.Parent = optionsFrame

            optBtn.MouseButton1Click:Connect(function()
                selectedLabel.Text = opt
                optionsFrame.Visible = false
                optionsFrame.Size = UDim2.new(1, 0, 0, 0)
                frame.ClipsDescendants = true
                if options.Callback then options.Callback(opt) end
            end)
        end
        optionsFrame.Size = UDim2.new(1, 0, 0, #opts * 36)
    end

    buildOptions(options.Options or {})

    local open = false
    headerBtn.MouseButton1Click:Connect(function()
        open = not open
        optionsFrame.Visible = open
        frame.ClipsDescendants = not open
        arrow.Text = open and "^" or "v"
    end)

    return {
        Set = function(opts)
            if opts.Options then buildOptions(opts.Options) end
            if opts.CurrentOption then selectedLabel.Text = opts.CurrentOption end
        end
    }
end

function MobileUI:Notification(options)
    local existing = player.PlayerGui:FindFirstChild("OdysseyMobileNotif")
    if existing then existing:Destroy() end

    local notifGui = Instance.new("ScreenGui")
    notifGui.Name = "OdysseyMobileNotif"
    notifGui.ResetOnSpawn = false
    notifGui.Parent = player.PlayerGui

    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 300, 0, 0)
    notif.AutomaticSize = Enum.AutomaticSize.Y
    notif.Position = UDim2.new(0.5, -150, 0, -100)
    notif.BackgroundColor3 = COLORS.card
    notif.BorderSizePixel = 0
    notif.Parent = notifGui
    corner(notif, 8)
    padding(notif, 10, 12, 12, 10)

    local layout = Instance.new("UIListLayout", notif)
    layout.Padding = UDim.new(0, 4)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, 0, 0, 18)
    titleLbl.BackgroundTransparency = 1
    titleLbl.TextColor3 = COLORS.text
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 12
    titleLbl.Text = options.Title or "Odyssey"
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = notif

    local contentLbl = Instance.new("TextLabel")
    contentLbl.Size = UDim2.new(1, 0, 0, 0)
    contentLbl.AutomaticSize = Enum.AutomaticSize.Y
    contentLbl.BackgroundTransparency = 1
    contentLbl.TextColor3 = COLORS.textSecondary
    contentLbl.Font = Enum.Font.Gotham
    contentLbl.TextSize = 11
    contentLbl.Text = options.Content or ""
    contentLbl.TextXAlignment = Enum.TextXAlignment.Left
    contentLbl.TextWrapped = true
    contentLbl.Parent = notif

    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -150, 0, 10)}):Play()

    task.delay(options.Duration or 3, function()
        TweenService:Create(notif, TweenInfo.new(0.2), {Position = UDim2.new(0.5, -150, 0, -100)}):Play()
        task.wait(0.2)
        notifGui:Destroy()
    end)
end

return MobileUI

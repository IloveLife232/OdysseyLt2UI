    main.Position = UDim2.new(0.5, -300, 0.5, -160)
    main.BackgroundColor3 = C.bg
    main.BorderSizePixel = 0
    main.Parent = gui
    corner(main, 16)
    stroke(main, C.border)
    self.main = main

    local topbar = Instance.new("Frame")
    topbar.Size = UDim2.new(1, 0, 0, 44)
    topbar.BackgroundColor3 = C.topbar
    topbar.BorderSizePixel = 0
    topbar.Parent = main
    corner(topbar, 16)

    local topbarFix = Instance.new("Frame")
    topbarFix.Size = UDim2.new(1, 0, 0, 16)
    topbarFix.Position = UDim2.new(0, 0, 1, -16)
    topbarFix.BackgroundColor3 = C.topbar
    topbarFix.BorderSizePixel = 0
    topbarFix.Parent = topbar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -100, 1, 0)
    titleLabel.Position = UDim2.new(0, 16, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = C.text
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 13
    titleLabel.Text = title or "Odyssey"
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topbar

    local minBtn = Instance.new("TextButton")
    minBtn.Size = UDim2.new(0, 26, 0, 26)
    minBtn.Position = UDim2.new(1, -62, 0, 9)
    minBtn.BackgroundColor3 = C.innerCard
    minBtn.TextColor3 = C.textSecondary
    minBtn.Font = Enum.Font.GothamBold
    minBtn.TextSize = 14
    minBtn.Text = "-"
    minBtn.BorderSizePixel = 0
    minBtn.Parent = topbar
    corner(minBtn, 7)

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 26, 0, 26)
    closeBtn.Position = UDim2.new(1, -32, 0, 9)
    closeBtn.BackgroundColor3 = C.innerCard
    closeBtn.TextColor3 = C.textSecondary
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 12
    closeBtn.Text = "X"
    closeBtn.BorderSizePixel = 0
    closeBtn.Parent = topbar
    corner(closeBtn, 7)
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)

    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        TweenService:Create(main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = minimized and UDim2.new(0, 600, 0, 44) or UDim2.new(0, 600, 0, 320)
        }):Play()
    end)

    local body = Instance.new("Frame")
    body.Size = UDim2.new(1, 0, 1, -44)
    body.Position = UDim2.new(0, 0, 0, 44)
    body.BackgroundTransparency = 1
    body.ClipsDescendants = true
    body.Parent = main
    self.body = body

    local sidebar = Instance.new("ScrollingFrame")
    sidebar.Size = UDim2.new(0, 58, 1, 0)
    sidebar.BackgroundColor3 = C.sidebar
    sidebar.BorderSizePixel = 0
    sidebar.ScrollBarThickness = 0
    sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    sidebar.AutomaticCanvasSize = Enum.AutomaticSize.Y
    sidebar.Parent = body
    self.sidebar = sidebar

    local sidebarFix = Instance.new("Frame")
    sidebarFix.Size = UDim2.new(1, 0, 0, 16)
    sidebarFix.BackgroundColor3 = C.sidebar
    sidebarFix.BorderSizePixel = 0
    sidebarFix.Parent = sidebar

    local sidebarLayout = Instance.new("UIListLayout", sidebar)
    sidebarLayout.Padding = UDim.new(0, 2)
    sidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pad(sidebar, 16, 5, 5, 8)

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0, 1, 1, 0)
    divider.Position = UDim2.new(0, 58, 0, 0)
    divider.BackgroundColor3 = C.border
    divider.BorderSizePixel = 0
    divider.Parent = body

    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, -59, 1, 0)
    content.Position = UDim2.new(0, 59, 0, 0)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 3
    content.ScrollBarImageColor3 = C.accent
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.Parent = body
    self.content = content

    local contentLayout = Instance.new("UIListLayout", content)
    contentLayout.Padding = UDim.new(0, 5)
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pad(content, 8, 8, 8, 8)
    self.contentLayout = contentLayout

    local dragging, dragStart, startPos = false, nil, nil
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return self
end

function MobileUI:CreateTab(name, icon)
    local tab = {}
    tab.name = name

    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, 0, 0, 46)
    tabBtn.BackgroundColor3 = C.card
    tabBtn.BorderSizePixel = 0
    tabBtn.Text = ""
    tabBtn.Parent = self.sidebar
    corner(tabBtn, 10)

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 22)
    iconLabel.Position = UDim2.new(0, 0, 0, 5)
    iconLabel.BackgroundTransparency = 1
    iconLabel.TextColor3 = C.textSecondary
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextSize = 16
    iconLabel.Text = icon or "●"
    iconLabel.Parent = tabBtn

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 14)
    nameLabel.Position = UDim2.new(0, 0, 0, 28)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = C.textSecondary
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 8
    nameLabel.Text = name
    nameLabel.Parent = tabBtn

    local tabContent = Instance.new("Frame")
    tabContent.Size = UDim2.new(1, 0, 1, 0)
    tabContent.BackgroundTransparency = 1
    tabContent.Visible = false
    tabContent.Parent = self.content

    local tabLayout = Instance.new("UIListLayout", tabContent)
    tabLayout.Padding = UDim.new(0, 5)
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder

    tab.frame = tabContent
    tab.btn = tabBtn
    tab.iconLabel = iconLabel
    tab.nameLabel = nameLabel
    tab.layout = tabLayout

    tabBtn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)

    table.insert(self.tabs, tab)
    if #self.tabs == 1 then self:SelectTab(tab) end

    return tab
end

function MobileUI:SelectTab(tab)
    for _, t in ipairs(self.tabs) do
        t.frame.Visible = false
        t.btn.BackgroundColor3 = C.card
        t.iconLabel.TextColor3 = C.textSecondary
        t.nameLabel.TextColor3 = C.textSecondary
    end
    tab.frame.Visible = true
    tab.btn.BackgroundColor3 = C.accentDark
    tab.iconLabel.TextColor3 = C.accent
    tab.nameLabel.TextColor3 = C.accent
    self.currentTab = tab
end


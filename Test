local function corner(p, r) local c = Instance.new("UICorner", p) c.CornerRadius = UDim.new(0, r or 8) end
local function pad(p, t, l, r, b) local u = Instance.new("UIPadding", p) u.PaddingTop = UDim.new(0, t or 8) u.PaddingLeft = UDim.new(0, l or 8) u.PaddingRight = UDim.new(0, r or 8) u.PaddingBottom = UDim.new(0, b or 8) end
local function stroke(p, c, t) local s = Instance.new("UIStroke", p) s.Color = c or Color3.fromRGB(42,42,42) s.Thickness = t or 1 end

function MobileUI.new(title)

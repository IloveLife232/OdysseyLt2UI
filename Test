local C = {
    bg = Color3.fromRGB(17, 17, 19),
    topbar = Color3.fromRGB(26, 26, 28),
    sidebar = Color3.fromRGB(26, 26, 28),
    card = Color3.fromRGB(30, 30, 32),
    innerCard = Color3.fromRGB(42, 42, 46),
    text = Color3.fromRGB(240, 240, 240),
    textSecondary = Color3.fromRGB(85, 85, 90),
    accent = Color3.fromRGB(10, 132, 255),

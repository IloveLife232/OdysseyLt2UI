function MobileUI:CreateDropdown(parent, options)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 46)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel = 0
    card.ClipsDescendants = false
    card.Parent = parent
    corner(card, 10)
    stroke(card, C.border)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.5, 0, 0, 18)
    nameLabel.Position = UDim2.new(0, 12, 0, 14)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = C.text
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.Text = options.Name or "Dropdown"
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = card

    local selectedBtn = Instance.new("TextButton")
    selectedBtn.Size = UDim2.new(0.48, 0, 0, 28)
    selectedBtn.Position = UDim2.new(0.5, 0, 0, 9)
    selectedBtn.BackgroundColor3 = C.innerCard
    selectedBtn.TextColor3 = C.accent
    selectedBtn.Font = Enum.Font.Gotham
    selectedBtn.TextSize = 10
    selectedBtn.Text = (options.CurrentOption or "Select") .. "  v"
    selectedBtn.BorderSizePixel = 0
    selectedBtn.Parent = card
    corner(selectedBtn, 7)

    local dropFrame = Instance.new("Frame")
    dropFrame.Size = UDim2.new(0.48, 0, 0, 0)
    dropFrame.Position = UDim2.new(0.5, 0, 0, 40)
    dropFrame.BackgroundColor3 = C.innerCard
    dropFrame.BorderSizePixel = 0
    dropFrame.Visible = false
    dropFrame.ZIndex = 10
    dropFrame.Parent = card
    corner(dropFrame, 8)
    stroke(dropFrame, C.border)

    local dropLayout = Instance.new("UIListLayout", dropFrame)
    dropLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local open = false

    local function buildOptions(opts)
        for _, child in ipairs(dropFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(opts) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 28)
            optBtn.BackgroundTransparency = 1
            optBtn.TextColor3 = C.text
            optBtn.Font = Enum.Font.Gotham
            optBtn.TextSize = 10
            optBtn.Text = opt
            optBtn.ZIndex = 11
            optBtn.Parent = dropFrame

            optBtn.MouseButton1Click:Connect(function()
                selectedBtn.Text = opt .. "  v"
                open = false
                dropFrame.Visible = false
                if options.Callback then options.Callback(opt) end
            end)
        end
        dropFrame.Size = UDim2.new(0.48, 0, 0, math.min(#opts, 5) * 28)
    end

    buildOptions(options.Options or {})

    selectedBtn.MouseButton1Click:Connect(function()
        open = not open
        dropFrame.Visible = open
        selectedBtn.Text = (dropFrame.Visible and selectedBtn.Text:gsub("  v", "  ^") or selectedBtn.Text:gsub("  ^", "  v"))
    end)

    return {
        Set = function(opts)
            if opts.Options then buildOptions(opts.Options) end
            if opts.CurrentOption then selectedBtn.Text = opts.CurrentOption .. "  v" end
        end
    }
end

function MobileUI:Notification(options)
    local existing = player.PlayerGui:FindFirstChild("OdysseyMobileNotif")
    if existing then existing:Destroy() end

    local notifGui = Instance.new("ScreenGui")
    notifGui.Name = "OdysseyMobileNotif"
    notifGui.ResetOnSpawn = false
    notifGui.IgnoreGuiInset = true
    notifGui.Parent = player.PlayerGui

    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 280, 0, 0)
    notif.AutomaticSize = Enum.AutomaticSize.Y
    notif.Position = UDim2.new(0.5, -140, 0, -80)
    notif.BackgroundColor3 = C.card
    notif.BorderSizePixel = 0
    notif.Parent = notifGui
    corner(notif, 10)
    stroke(notif, C.border)
    pad(notif, 10, 14, 14, 10)

    local layout = Instance.new("UIListLayout", notif)
    layout.Padding = UDim.new(0, 3)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, 0, 0, 16)
    titleLbl.BackgroundTransparency = 1
    titleLbl.TextColor3 = C.text
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 11
    titleLbl.Text = options.Title or "Odyssey"
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = notif

    local contentLbl = Instance.new("TextLabel")
    contentLbl.Size = UDim2.new(1, 0, 0, 0)
    contentLbl.AutomaticSize = Enum.AutomaticSize.Y
    contentLbl.BackgroundTransparency = 1
    contentLbl.TextColor3 = C.textSecondary
    contentLbl.Font = Enum.Font.Gotham
    contentLbl.TextSize = 10
    contentLbl.Text = options.Content or ""
    contentLbl.TextXAlignment = Enum.TextXAlignment.Left
    contentLbl.TextWrapped = true
    contentLbl.Parent = notif

    TweenService:Create(notif, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -140, 0, 10)
    }):Play()

    task.delay(options.Duration or 3, function()
        TweenService:Create(notif, TweenInfo.new(0.2), {
            Position = UDim2.new(0.5, -140, 0, -80)
        }):Play()
        task.wait(0.25)
        notifGui:Destroy()
    end)
end

return MobileUI

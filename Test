function MobileUI:CreateToggle(parent, options)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, options.Description and 56 or 46)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel = 0
    card.Parent = parent
    corner(card, 10)
    stroke(card, C.border)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -70, 0, 18)
    nameLabel.Position = UDim2.new(0, 12, 0, options.Description and 8 or 14)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = C.text
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.Text = options.Name or "Toggle"
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = card

    if options.Description then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -70, 0, 14)
        desc.Position = UDim2.new(0, 12, 0, 28)
        desc.BackgroundTransparency = 1
        desc.TextColor3 = C.textSecondary
        desc.Font = Enum.Font.Gotham
        desc.TextSize = 9
        desc.Text = options.Description
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.TextWrapped = true
        desc.Parent = card
    end

    local toggleBg = Instance.new("Frame")
    toggleBg.Size = UDim2.new(0, 42, 0, 24)
    toggleBg.Position = UDim2.new(1, -54, 0.5, -12)
    toggleBg.BackgroundColor3 = options.CurrentValue and C.on or C.off
    toggleBg.BorderSizePixel = 0
    toggleBg.Parent = card
    corner(toggleBg, 12)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = options.CurrentValue and UDim2.new(0, 21, 0, 3) or UDim2.new(0, 3, 0, 3)
    knob.BackgroundColor3 = C.white
    knob.BorderSizePixel = 0
    knob.Parent = toggleBg
    corner(knob, 9)

    local value = options.CurrentValue or false

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = card

    btn.MouseButton1Click:Connect(function()
        value = not value
        TweenService:Create(toggleBg, TweenInfo.new(0.15), {BackgroundColor3 = value and C.on or C.off}):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {Position = value and UDim2.new(0, 21, 0, 3) or UDim2.new(0, 3, 0, 3)}):Play()
        if options.Callback then options.Callback(value) end
    end)

    local toggle = {}
    function toggle:Set(v)
        value = v
        TweenService:Create(toggleBg, TweenInfo.new(0.15), {BackgroundColor3 = v and C.on or C.off}):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {Position = v and UDim2.new(0, 21, 0, 3) or UDim2.new(0, 3, 0, 3)}):Play()
    end

    return toggle
end

function MobileUI:CreateSlider(parent, options)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 68)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel = 0
    card.Parent = parent
    corner(card, 10)
    stroke(card, C.border)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -60, 0, 18)
    nameLabel.Position = UDim2.new(0, 12, 0, 8)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = C.text
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.Text = options.Name or "Slider"
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = card

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0, 50, 0, 18)
    valLabel.Position = UDim2.new(1, -62, 0, 8)
    valLabel.BackgroundTransparency = 1
    valLabel.TextColor3 = C.accent
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextSize = 12
    valLabel.Text = tostring(options.CurrentValue or options.Range[1])
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Parent = card

    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1, -24, 0, 4)
    trackBg.Position = UDim2.new(0, 12, 0, 42)
    trackBg.BackgroundColor3 = C.innerCard
    trackBg.BorderSizePixel = 0
    trackBg.Parent = card
    corner(trackBg, 2)

    local trackFill = Instance.new("Frame")
    trackFill.Size = UDim2.new(0, 0, 1, 0)
    trackFill.BackgroundColor3 = C.accent
    trackFill.BorderSizePixel = 0
    trackFill.Parent = trackBg
    corner(trackFill, 2)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 16, 0, 16)
    thumb.AnchorPoint = Vector2.new(1, 0.5)
    thumb.Position = UDim2.new(0, 0, 0.5, 0)
    thumb.BackgroundColor3 = C.white
    thumb.BorderSizePixel = 0
    thumb.Parent = trackFill
    corner(thumb, 8)

    local range = options.Range or {0, 100}
    local increment = options.Increment or 1
    local currentValue = options.CurrentValue or range[1]

    local function updateSlider(val)
        val = math.clamp(math.floor(val / increment + 0.5) * increment, range[1], range[2])
        currentValue = val
        local pct = (val - range[1]) / (range[2] - range[1])
        trackFill.Size = UDim2.new(pct, 0, 1, 0)
        valLabel.Text = tostring(val)
        if options.Callback then options.Callback(val) end
    end

    updateSlider(currentValue)

    local dragging = false
    local dragBtn = Instance.new("TextButton")
    dragBtn.Size = UDim2.new(1, -24, 0, 28)
    dragBtn.Position = UDim2.new(0, 12, 0, 32)
    dragBtn.BackgroundTransparency = 1
    dragBtn.Text = ""
    dragBtn.Parent = card

    dragBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            local relX = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
            updateSlider(range[1] + relX * (range[2] - range[1]))
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local relX = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
            updateSlider(range[1] + relX * (range[2] - range[1]))
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return {Set = function(v) updateSlider(v) end}
end

